msgstr "%d soccorritore/i configurato/i, chiamati %s."

#: Loneworker.class.php:687
msgid "There are external responder numbers but no outbound routes exist: the alarm cannot call them."
msgstr "Ci sono numeri esterni ma non esistono outbound route: l'allarme non può chiamarli."

#: Loneworker.class.php:691
#, php-format
msgid "No enabled outbound route matches external number %s."
msgstr "Nessuna outbound route abilitata corrisponde al numero esterno %s."

#: Loneworker.class.php:692
#, php-format
msgid "External number %s only matches a route filtered by Caller ID; the alarm Caller ID may not pass it."
msgstr "Il numero esterno %s corrisponde solo a una route filtrata per Caller ID; il Caller ID dell'allarme potrebbe non superarla."

#: Loneworker.class.php:693
#, php-format
msgid "External number %s matches route \"%s\" but its trunk is disabled."
msgstr "Il numero esterno %s corrisponde alla route \"%s\" ma il suo trunk è disabilitato."

#: Loneworker.class.php:694
#, php-format
msgid "External number %s will route out via \"%s\"."
msgstr "Il numero esterno %s uscirà tramite \"%s\"."

#: Loneworker.class.php:698
#, php-format
msgid "External calls will present Caller ID %s."
msgstr "Le chiamate esterne presenteranno il Caller ID %s."

#: Loneworker.class.php:701
msgid "No alarm Caller ID set: external calls go out as the down worker extension. If the trunk/route has no outbound CID, the carrier may receive an internal number. Set a service extension or an explicit Caller ID."
msgstr "Nessun Caller ID d'allarme impostato: le chiamate esterne escono come l'interno dell'operatore caduto. Se trunk/route non hanno un outbound CID, l'operatore telefonico potrebbe ricevere un numero interno. Imposta un interno di servizio o un Caller ID esplicito."

#: Loneworker.class.php:704
#, php-format
msgid "Service extension %s has no outbound Caller ID: the carrier may receive an internal number. Set its Outbound CID or an explicit Caller ID."
msgstr "L'interno di servizio %s non ha un outbound Caller ID: l'operatore telefonico potrebbe ricevere un numero interno. Imposta il suo Outbound CID o un Caller ID esplicito."

#: Loneworker.class.php:705
#, php-format
msgid "External calls will use the outbound Caller ID of extension %s (%s)."
msgstr "Le chiamate esterne useranno l'outbound Caller ID dell'interno %s (%s)."

