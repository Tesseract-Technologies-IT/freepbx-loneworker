# ---- live example (JS) ----
#: views/settings.php:63
msgid "What will happen (live example)"
msgstr "Cosa accadrà (esempio dal vivo)"

#: views/settings.php:64
msgid "Example for extension %EXT% based on the current settings:"
msgstr "Esempio per l'interno %EXT% in base alle impostazioni attuali:"

#: views/settings.php:65
msgid "%EXT% dials %ARM% → the speakers (paging group %PG%) announce that the lone worker system is armed for extension %EXT%, and a %TIMEOUT%-minute countdown starts."
msgstr "%EXT% compone %ARM% → le casse (gruppo paging %PG%) annunciano che il sistema uomo a terra è attivato per l'interno %EXT% e parte un conto alla rovescia di %TIMEOUT% minuti."

#: views/settings.php:66
msgid "After %REMAFTER% minutes a reminder is announced on the speakers, then repeated every %REMINT% minutes until the deadline."
msgstr "Dopo %REMAFTER% minuti viene annunciato un promemoria sulle casse, poi ripetuto ogni %REMINT% minuti fino alla scadenza."

#: views/settings.php:67
msgid "%EXT% dials %CHK% at any time → the timer resets to %TIMEOUT% minutes (\"I am OK\") and everyone hears the confirmation."
msgstr "%EXT% compone %CHK% in qualsiasi momento → il timer si azzera a %TIMEOUT% minuti (\"sto bene\") e tutti sentono la conferma."

#: views/settings.php:68
msgid "If %TIMEOUT% minutes pass with no %CHK% → an alarm is announced on the speakers and ALL configured responders are called at the same time. The first responder to press %KEY% takes charge of the alarm, and all the other calls stop immediately."
msgstr "Se passano %TIMEOUT% minuti senza %CHK% → viene annunciato un allarme sulle casse e TUTTI i soccorritori configurati vengono chiamati contemporaneamente. Il primo soccorritore che preme %KEY% prende in carico l'allarme e tutte le altre chiamate si interrompono immediatamente."

#: views/settings.php:69
msgid "If %TIMEOUT% minutes pass with no %CHK% → an alarm is announced on the speakers and the responders are called one at a time, in list order, until someone presses %KEY% to take charge."
msgstr "Se passano %TIMEOUT% minuti senza %CHK% → viene annunciato un allarme sulle casse e i soccorritori vengono chiamati uno alla volta, nell'ordine della lista, finché qualcuno non preme %KEY% per prendere in carico."

#: views/settings.php:70
msgid "%EXT% dials %DIS% → the session is closed and the speakers announce it was disarmed."
msgstr "%EXT% compone %DIS% → la sessione si chiude e le casse annunciano la disattivazione."

#: views/settings.php:71
msgid "⚠ No paging group selected: announcements on the speakers will not work until you pick one below."
msgstr "⚠ Nessun gruppo paging selezionato: gli annunci sulle casse non funzioneranno finché non ne scegli uno qui sotto."

#: views/settings.php:72
msgid "⚠ No responders configured: the emergency call cascade will not work until you add internal and/or external numbers below."
msgstr "⚠ Nessun soccorritore configurato: la cascata d'emergenza non funzionerà finché non aggiungi interni e/o numeri esterni qui sotto."

#: views/settings.php:73
msgid "Preview extension (used only for this example, not saved)"
msgstr "Interno di esempio (usato solo per questa anteprima, non salvato)"

#: views/settings.php:102
msgid "Problems to fix before alarms work reliably"
msgstr "Problemi da risolvere prima che gli allarmi funzionino in modo affidabile"

#: views/settings.php:102
