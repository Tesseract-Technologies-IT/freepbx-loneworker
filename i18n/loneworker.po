# ---- live example (JS) ----
#: views/settings.php:63
msgid "What will happen (live example)"
msgstr "Cosa accadrà (esempio dal vivo)"

#: views/settings.php:64
msgid "Example for extension %EXT% based on the current settings:"
msgstr "Esempio per l'interno %EXT% in base alle impostazioni attuali:"

#: views/settings.php:65
msgid ""
"%EXT% dials %ARM% → the speakers (paging group %PG%) announce that the lone "
"worker system is armed for extension %EXT%, and a %TIMEOUT%-minute countdown "
"starts."
msgstr ""
"%EXT% compone %ARM% → le casse (gruppo paging %PG%) annunciano che il "
"sistema uomo a terra è attivato per l'interno %EXT% e parte un conto alla "
"rovescia di %TIMEOUT% minuti."

#: views/settings.php:66
msgid ""
"After %REMAFTER% minutes a reminder is announced on the speakers, then "
"repeated every %REMINT% minutes until the deadline."
msgstr ""
"Dopo %REMAFTER% minuti viene annunciato un promemoria sulle casse, poi "
"ripetuto ogni %REMINT% minuti fino alla scadenza."

#: views/settings.php:67
msgid ""
"%EXT% dials %CHK% at any time → the timer resets to %TIMEOUT% minutes (\"I "
"am OK\") and everyone hears the confirmation."
msgstr ""
"%EXT% compone %CHK% in qualsiasi momento → il timer si azzera a %TIMEOUT% "
"minuti (\"sto bene\") e tutti sentono la conferma."

#: views/settings.php:68
msgid ""
"If %TIMEOUT% minutes pass with no %CHK% → an alarm is announced on the "
"speakers and ALL configured responders are called at the same time. The "
"first responder to press 1 takes charge of the alarm, and all the other "
"calls stop immediately."
msgstr ""
"Se passano %TIMEOUT% minuti senza %CHK% → viene annunciato un allarme sulle "
"casse e TUTTI i soccorritori configurati vengono chiamati "
"contemporaneamente. Il primo soccorritore che preme 1 prende in carico "
"l'allarme e tutte le altre chiamate si interrompono immediatamente."

#: views/settings.php:69
msgid ""
"If %TIMEOUT% minutes pass with no %CHK% → an alarm is announced on the "
"speakers and the responders are called one at a time, in list order, until "
"someone presses 1 to take charge."
msgstr ""
"Se passano %TIMEOUT% minuti senza %CHK% → viene annunciato un allarme sulle "
"casse e i soccorritori vengono chiamati uno alla volta, nell'ordine della "
"lista, finché qualcuno preme 1 per prendere in carico."

#: views/settings.php:70
msgid ""
"%EXT% dials %DIS% → the session is closed and the speakers announce it was "
"disarmed."
msgstr ""
"%EXT% compone %DIS% → la sessione si chiude e le casse annunciano la "
"disattivazione."

#: views/settings.php:71
msgid ""
"⚠ No paging group selected: announcements on the speakers will not work "
"until you pick one below."
msgstr ""
"⚠ Nessun gruppo paging selezionato: gli annunci sulle casse non "
"funzioneranno finché non ne scegli uno qui sotto."

#: views/settings.php:72
msgid ""
"⚠ No responders configured: the emergency call cascade will not work until "
"you add internal and/or external numbers below."
msgstr ""
"⚠ Nessun soccorritore configurato: la cascata d'emergenza non funzionerà "
"finché non aggiungi interni e/o numeri esterni qui sotto."

#: views/settings.php:73
msgid "Preview extension (used only for this example, not saved)"
msgstr "Interno di esempio (usato solo per questa anteprima, non salvato)"

#: views/settings.php:102
msgid "Problems to fix before alarms work reliably"
msgstr ""
"Problemi da risolvere prima che gli allarmi funzionino in modo affidabile"

#: views/settings.php:102
msgid "Ready, with warnings"
msgstr "Pronto, con avvisi"

#: views/settings.php:102
msgid "Ready for alarms"
msgstr "Pronto per gli allarmi"

#: views/settings.php:107
msgid "Readiness check"
msgstr "Check di prontezza"

#: views/settings.php:108
msgid "Re-check"
msgstr "Ricontrolla"

#: views/settings.php:124 views/settings.php:132
msgid "Timers"
msgstr "Tempi"

# ---- v1.8: settings tabs ----
#: views/settings.php:125
msgid "Feature codes"
msgstr "Feature code"

#: views/settings.php:126
msgid "Responders & calls"
msgstr "Soccorritori e chiamate"

#: views/settings.php:127
msgid "Limits"
msgstr "Limiti"

#: views/settings.php:128
msgid "Announcements"
msgstr "Annunci"

#: views/settings.php:134
msgid "Timeout before alarm (seconds)"
msgstr "Timeout prima dell'allarme (secondi)"

#: views/settings.php:134
msgid ""
"How long an armed operator has to confirm before the alarm fires. Resets on "
"every check-in (702). Default 1800 = 30 minutes."
msgstr ""
"Quanto tempo ha l'operatore armato per confermare prima che scatti "
"l'allarme. Si azzera a ogni conferma (702). Predefinito 1800 = 30 minuti."

#: views/settings.php:135
msgid "First reminder after (seconds)"
msgstr "Primo promemoria dopo (secondi)"

#: views/settings.php:135
msgid ""
"Time from arm/check-in to the first reminder on the speakers. Default 900 = "
"15 minutes. Must be smaller than the timeout."
msgstr ""
"Tempo dall'armamento/conferma al primo promemoria sulle casse. Predefinito "
"900 = 15 minuti. Deve essere inferiore al timeout."

#: views/settings.php:136
msgid "Reminder interval (seconds)"
msgstr "Intervallo tra i promemoria (secondi)"

#: views/settings.php:136
msgid ""
"How often the reminder repeats after the first one, until the deadline. "
"Default 300 = 5 minutes."
msgstr ""
"Ogni quanto si ripete il promemoria dopo il primo, fino alla scadenza. "
"Predefinito 300 = 5 minuti."

# ---- feature codes (editable) ----
#: views/settings.php:141
msgid "Feature codes (numbers to dial)"
msgstr "Feature code (numeri da comporre)"

#: views/settings.php:144 Loneworker.class.php:171
msgid "Arm code"
msgstr "Codice di armamento"

#: views/settings.php:144
msgid "Number the operator dials to arm a session (default 701)."
msgstr ""
"Numero che l'operatore compone per armare una sessione (predefinito 701)."

#: views/settings.php:145 Loneworker.class.php:171
msgid "Check-in code"
msgstr "Codice di conferma"

#: views/settings.php:145
msgid ""
"Number the operator dials to confirm presence (default 702). This number is "
"announced dynamically inside the \"armed\" and \"reminder\" messages, so if "
"you change it the audio follows automatically."
msgstr ""
"Numero che l'operatore compone per confermare la presenza (predefinito 702). "
"Questo numero viene pronunciato dinamicamente negli annunci \"armato\" e "
"\"promemoria\", quindi se lo cambi l'audio si adegua automaticamente."

#: views/settings.php:146 Loneworker.class.php:171
msgid "Disarm code"
msgstr "Codice di disarmo"

#: views/settings.php:146
msgid "Number the operator dials to disarm their session (default 703)."
msgstr ""
"Numero che l'operatore compone per disarmare la propria sessione "
"(predefinito 703)."

#: views/settings.php:160
msgid "Audio & call routing"
msgstr "Audio e instradamento chiamate"

#: views/settings.php:162
msgid "Paging group (speakers)"
msgstr "Gruppo paging (casse)"

#: views/settings.php:165
msgid ""
"The paging/intercom group whose speakers play every announcement (armed, "
"reminder, confirmed, alarm, acknowledged, disarmed). Create it under "
"Applications → Paging and Intercom."
msgstr ""
"Il gruppo paging/intercom le cui casse riproducono tutti gli annunci "
"(armato, promemoria, confermato, allarme, preso in carico, disarmato). "
"Crealo in Applicazioni → Paging and Intercom."

# ---- v1.6: unified ordered list + call mode ----
#: views/settings.php:182
msgid "Numbers to call (in order)"
msgstr "Numeri da chiamare (in ordine)"

#: views/settings.php:188
msgid "Pick an extension…"
msgstr "Scegli un interno…"

#: views/settings.php:191
msgid "Add to list"
msgstr "Aggiungi alla lista"

#: views/settings.php:200
msgid ""
"One number per line, in the order they should be tried — internal extensions "
"and external numbers together. Use the picker to add an internal extension, "
"or just type a number. External numbers are dialed through your outbound "
"routes (see the Readiness panel above)."
msgstr ""
"Un numero per riga, nell'ordine in cui vanno provati — interni e numeri "
"esterni insieme. Usa il selettore per aggiungere un interno, o digita un "
"numero. I numeri esterni vengono composti tramite le tue outbound route "
"(vedi il pannello Prontezza qui sopra)."

#: views/settings.php:204
msgid "Call mode"
msgstr "Modalità di chiamata"

#: views/settings.php:207
msgid "All at once (ring everyone together)"
msgstr "Tutti insieme (squilla a tutti contemporaneamente)"

#: views/settings.php:208
msgid "In sequence (one at a time, in list order)"
msgstr "In sequenza (uno alla volta, nell'ordine della lista)"

#: views/settings.php:212
msgid ""
"All at once: every number rings at the same time; the first to press 1 takes "
"charge and the others stop. In sequence: each number is tried for the ring "
"time, one after another in list order, until someone presses 1."
msgstr ""
"Tutti insieme: ogni numero squilla nello stesso momento; il primo che preme "
"1 prende in carico e gli altri si interrompono. In sequenza: ogni numero "
"viene provato per la durata dello squillo, uno dopo l'altro nell'ordine "
"della lista, finché qualcuno preme 1."

#: views/settings.php:214
msgid "Alarm ring time (seconds)"
msgstr "Durata squillo allarme (secondi)"

#: views/settings.php:214
msgid ""
"How long each responder rings during an alarm before giving up (per "
"attempt). Default 45."
msgstr ""
"Per quanto tempo squilla ogni soccorritore durante un allarme prima di "
"rinunciare (per tentativo). Predefinito 45."

# ---- escalation / language / test / event history ----
#: views/settings.php:215
msgid "Repeat alarm every (seconds)"
msgstr "Ripeti l'allarme ogni (secondi)"

#: views/settings.php:215
msgid ""
"If nobody presses 1, the alarm is re-announced and the responders are called "
"again every this many seconds, until someone takes charge or an operator "
"disarms. Keep it larger than the ring time. Default 120 (2 min)."
msgstr ""
"Se nessuno preme 1, l'allarme viene riannunciato e i soccorritori vengono "
"richiamati ogni tot secondi, finché qualcuno prende in carico o un operatore "
"disarma. Tienilo maggiore della durata dello squillo. Predefinito 120 (2 "
"min)."

#: views/settings.php:219
msgid "Spoken number language"
msgstr "Lingua dei numeri pronunciati"

#: views/settings.php:227
msgid ""
"Language used to speak the extension and the check-in number (SayDigits). "
"Set it to match your recordings (default Italian), otherwise the numbers are "
"spoken in the system default language."
msgstr ""
"Lingua usata per pronunciare l'interno e il numero di conferma (SayDigits). "
"Impostala in base alle tue registrazioni (predefinito italiano), altrimenti "
"i numeri vengono detti nella lingua di default del sistema."

#: views/settings.php:229
msgid "Alarm calls Caller ID (for external numbers)"
msgstr "Caller ID delle chiamate d'allarme (per i numeri esterni)"

#: views/settings.php:231
msgid "Service extension for alarm calls"
msgstr "Interno di servizio per le chiamate d'allarme"

#: views/settings.php:234
msgid "(the down worker's own extension)"
msgstr "(l'interno dell'operatore caduto)"

#: views/settings.php:241
msgid ""
"External alarm calls go out with this extension's identity — they inherit "
"its Outbound CID and pass its CID-filtered outbound routes. Leave on default "
"to call out as the down worker's extension."
msgstr ""
"Le chiamate d'allarme esterne escono con l'identità di questo interno — ne "
"ereditano l'Outbound CID e superano le sue outbound route con filtro CID. "
"Lascia il default per chiamare con l'interno dell'operatore caduto."

#: views/settings.php:244
msgid "Explicit outbound Caller ID"
msgstr "CallerID esplicito in uscita"

#: views/settings.php:247
msgid ""
"If set, this number is presented as Caller ID on external alarm calls and "
"OVERRIDES the service extension. Use a number your carrier accepts and that "
"your outbound routes do not filter out. The spoken announcement still says "
"the down worker's extension."
msgstr ""
"Se impostato, questo numero viene presentato come Caller ID nelle chiamate "
"d'allarme esterne e HA PRIORITÀ sull'interno di servizio. Usa un numero "
"accettato dal tuo operatore e non filtrato dalle tue outbound route. "
"L'annuncio vocale continua a dire l'interno dell'operatore caduto."

#: views/settings.php:251
msgid "Play a test announcement on the speakers now?"
msgstr "Riprodurre ora un annuncio di prova sulle casse?"

#: views/settings.php:251
msgid "Test announcement (speakers)"
msgstr "Prova annuncio (casse)"

#: views/settings.php:252
msgid "Place a test alarm call to the responders now?"
msgstr "Avviare ora una chiamata d'allarme di prova ai soccorritori?"

#: views/settings.php:252
msgid "Test alarm call"
msgstr "Prova chiamata d'allarme"

#: views/settings.php:253
msgid ""
"Tests use the current settings and a fake extension (000); they do not "
"create a session."
msgstr ""
"Le prove usano le impostazioni attuali e un interno fittizio (000); non "
"creano una sessione."

#: views/settings.php:258
msgid "Limits & authorisation"
msgstr "Limiti e autorizzazioni"

#: views/settings.php:260
msgid "Authorised extensions"
msgstr "Interni autorizzati"

#: views/settings.php:263
msgid ""
"Space- or comma-separated list of extensions allowed to use 701/702/703. "
"Leave empty to allow every extension. The acting extension is taken from the "
"phone's Caller ID, so each operator can only control their own session."
msgstr ""
"Elenco di interni (separati da spazi o virgole) abilitati a usare "
"701/702/703. Lascia vuoto per autorizzare tutti gli interni. L'interno che "
"agisce è preso dal Caller ID del telefono, così ogni operatore può gestire "
"solo la propria sessione."

#: views/settings.php:265
msgid "Max concurrent sessions"
msgstr "Sessioni contemporanee max"

#: views/settings.php:265
msgid ""
"Safety cap on how many operators can be armed at the same time. Further arm "
"attempts are rejected with an error tone."
msgstr ""
"Limite di sicurezza sul numero di operatori armati contemporaneamente. "
"Ulteriori tentativi di armamento vengono rifiutati con un tono di errore."

#: views/settings.php:266
msgid "Event retention (days)"
msgstr "Conservazione eventi (giorni)"

#: views/settings.php:266
msgid ""
"Audit events (arm, check-in, alarm, acknowledge, etc.) older than this are "
"deleted automatically. 0 = keep forever."
msgstr ""
"Gli eventi (arma, conferma, allarme, presa in carico, ecc.) più vecchi di "
"questo valore vengono cancellati automaticamente. 0 = conserva per sempre."

#: views/settings.php:271
msgid "Announcements (System Recordings)"
msgstr "Annunci (System Recordings)"

#: views/settings.php:272
msgid ""
"Each announcement is split into a \"before\" and an \"after\" part; between "
"them the system speaks the extension number digit by digit, e.g. \"..."
"extension 3-0-1...\". Record the messages under Admin → System Recordings, "
"then pick them here."
msgstr ""
"Ogni annuncio è diviso in una parte \"prima\" e una \"dopo\"; tra le due il "
"sistema pronuncia il numero dell'interno cifra per cifra, es. \"...interno "
"3-0-1...\". Registra i messaggi in Admin → System Recordings e poi "
"selezionali qui."

# ---- announcement cards (cross-referenced selectors + audience) ----
#: views/settings.php:278
msgid "Armed — played when an operator dials 701"
msgstr "Armato — riprodotto quando un operatore compone 701"

#: views/settings.php:279
msgid "Attention. Lone worker system armed for extension"
msgstr "Attenzione. Sistema uomo a terra attivato per l'interno"

#: views/settings.php:280
msgid "must confirm they are OK within 30 minutes by calling number"
msgstr "deve confermare di stare bene entro trenta minuti chiamando il numero"

#: views/settings.php:281
msgid "Confirmed — played when an operator dials 702"
msgstr "Confermato — riprodotto quando un operatore compone 702"

#: views/settings.php:282
msgid "Lone worker: extension"
msgstr "Uomo a terra: l'interno"

#: views/settings.php:283
msgid "has confirmed their presence. The system stays active."
msgstr "ha confermato la propria presenza. Il sistema rimane attivo."

#: views/settings.php:284
msgid "Reminder — played before the deadline"
msgstr "Promemoria — riprodotto prima della scadenza"

#: views/settings.php:285
msgid "Lone worker reminder. Extension"
msgstr "Promemoria uomo a terra. L'interno"

#: views/settings.php:286
msgid ""
"must confirm presence. Only a few minutes remain before the alarm. Call "
"number"
msgstr ""
"deve confermare la propria presenza. Restano pochi minuti prima "
"dell'allarme. Chiamare il numero"

#: views/settings.php:287
msgid "Alarm — played when the timeout expires"
msgstr "Allarme — riprodotto allo scadere del timeout"

#: views/settings.php:288
msgid "Lone worker alarm. Extension"
msgstr "Allarme uomo a terra. L'interno"

#: views/settings.php:289
msgid ""
"did not confirm. Check the operator immediately. Emergency calls have been "
"started."
msgstr ""
"non ha confermato la propria presenza. Verificare immediatamente le "
"condizioni dell'operatore. Sono state attivate le chiamate d'emergenza."

#: views/settings.php:290
msgid "Acknowledged — played when a responder takes charge"
msgstr "Preso in carico — riprodotto quando un soccorritore prende in carico"

#: views/settings.php:291
msgid "Lone worker alarm taken charge of for extension"
msgstr "Allarme uomo a terra preso in carico per l'interno"

#: views/settings.php:292
msgid "A responder is checking the situation on site."
msgstr "Un soccorritore sta verificando la situazione sul posto."

#: views/settings.php:293
msgid "Disarmed — played when an operator dials 703"
msgstr "Disarmato — riprodotto quando un operatore compone 703"

#: views/settings.php:294
msgid "Lone worker system disarmed for extension"
msgstr "Sistema uomo a terra disattivato per l'interno"

#: views/settings.php:296
msgid "Emergency call — played to the responders during the alarm"
msgstr "Chiamata d'emergenza — riprodotto ai soccorritori durante l'allarme"

#: views/settings.php:297
msgid "Lone worker alarm. The operator of extension"
msgstr "Allarme uomo a terra. L'operatore dell'interno"

#: views/settings.php:298
msgid "did not confirm. Press 1 to take charge of the alarm."
msgstr ""
"non ha confermato la propria presenza. Premere uno per prendere in carico "
"l'allarme."

#: views/settings.php:304
msgid ""
"Heard on the responders' phones (the internal extensions and external "
"numbers configured below) — only the person who answers the call hears this."
msgstr ""
"Si sente sui telefoni dei soccorritori (gli interni e i numeri esterni "
"configurati qui sotto) — lo sente solo chi risponde alla chiamata."

#: views/settings.php:307
#, php-format
msgid ""
"Heard on the speakers (paging group %s) — everyone near the speakers hears "
"this."
msgstr ""
"Si sente sulle casse (gruppo paging %s) — lo sentono tutti vicino alle casse."

#: views/settings.php:328
msgid "Recording — part 1 (before the number)"
msgstr "Registrazione — parte 1 (prima del numero)"

#: views/settings.php:329
msgid "Recording — part 2 (after the number)"
msgstr "Registrazione — parte 2 (dopo il numero)"

#: views/settings.php:332
msgid ""
"The check-in number is spoken automatically here (SayDigits), taken from the "
"Check-in feature code above — do not record it into the audio."
msgstr ""
"Il numero di conferma viene pronunciato automaticamente qui (SayDigits), "
"preso dal Codice di conferma qui sopra — non registrarlo nell'audio."

# ---- feature code labels ----
#: Loneworker.class.php:55
msgid "Lone Worker: Arm"
msgstr "Uomo a Terra: Arma"

#: Loneworker.class.php:55
msgid "Lone Worker: Check-in"
msgstr "Uomo a Terra: Conferma presenza"

#: Loneworker.class.php:55
msgid "Lone Worker: Disarm"
msgstr "Uomo a Terra: Disarma"

# ---- feature code conflict detection ----
#: Loneworker.class.php:153
#, php-format
msgid "extension %s (%s)"
msgstr "interno %s (%s)"

#: Loneworker.class.php:161
#, php-format
msgid "feature code %s/%s"
msgstr "feature code %s/%s"

